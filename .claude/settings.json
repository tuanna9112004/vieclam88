{
  "autoCompactEnabled": true,
  "autoMemoryEnabled": false,
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git grep*)",
      "Bash(php artisan test*)",
      "Bash(php artisan route:list*)",
      "Bash(php artisan about*)",
      "Bash(php artisan migrate:status*)",
      "Bash(npm run build*)",
      "Bash(composer validate*)",
      "Bash(python scripts/check-claude-skills.py*)",
      "Bash(python scripts/check-claude-config.py*)",
      "Bash(python -m py_compile*)"
    ],
    "ask": [
      "Bash(composer create-project*)",
      "Bash(composer install*)",
      "Bash(composer update*)",
      "Bash(npm install*)",
      "Bash(npm ci*)",
      "Bash(php artisan migrate*)",
      "Bash(git commit*)",
      "Bash(git tag*)",
      "Bash(git push*)",
      "Bash(rm *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./storage/app/private/**)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)"
    ]
  }
}
