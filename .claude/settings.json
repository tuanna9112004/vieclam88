{
  "autoCompactEnabled": true,
  "autoMemoryEnabled": false,
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)"
    ],
    "ask": [],
    "deny": [
      "Read(./.env)",
      "Read(./storage/app/private/**)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)"
    ]
  }
}
